{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Android",
      "cwd": "${workspaceFolder}",
      "type": "reactnative",
      "request": "launch",
      "platform": "android",
      "env": {
        "PATH": "${env:PATH}"
      }
    },
    {
      "name": "Debug iOS",
      "cwd": "${workspaceFolder}",
      "type": "reactnative",
      "request": "launch",
      "platform": "ios",
      "env": {
        "PATH": "${env:PATH}"
      }
    },
    {
      "name": "Attach to packager",
      "cwd": "${workspaceFolder}",
      "type": "reactnative",
      "request": "attach"
    },
    {
      "name": "Attach to Hermes",
      "type": "reactnative",
      "request": "attach",
      "cwd": "${workspaceFolder}",
      "platform": "android",
      "port": 8081,
      "sourceMaps": true
    }
  ]
}